      "required": [
        "sample_id",
        "symbol",
        "side",
        "volume_lots",
        "open_price",
        "close_price",
        "mt5_profit",
        "mt5_margin"
      ],
      "title": "Mt5CalculationSample",
      "type": "object"
    },
