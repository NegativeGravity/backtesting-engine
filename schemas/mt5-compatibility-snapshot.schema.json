{
  "$defs": {
    "CurrencyCode": {
      "maxLength": 8,
      "minLength": 3,
      "pattern": "^[A-Z0-9]+$",
      "type": "string"
    },
    "Identifier": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$",
      "type": "string"
    },
    "Mt5AccountSnapshot": {
      "additionalProperties": false,
      "properties": {
        "balance": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Balance"
        },
        "company": {
          "title": "Company",
          "type": "string"
        },
        "credit": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Credit"
        },
        "currency": {
          "$ref": "#/$defs/CurrencyCode"
        },
        "equity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Equity"
        },
        "leverage": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Leverage"
        },
        "login": {
          "minimum": 0,
          "title": "Login",
          "type": "integer"
        },
        "margin": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Margin"
        },
        "margin_free": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Margin Free"
        },
        "margin_level": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Margin Level"
        },
        "margin_so_call": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Margin So Call"
        },
        "margin_so_mode": {
          "minimum": 0,
          "title": "Margin So Mode",
          "type": "integer"
        },
        "margin_so_so": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Margin So So"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "position_mode": {
          "$ref": "#/$defs/PositionMode"
        },
        "profit": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Profit"
        },
        "server": {
          "title": "Server",
          "type": "string"
        },
        "trade_allowed": {
          "title": "Trade Allowed",
          "type": "boolean"
        },
        "trade_expert": {
          "title": "Trade Expert",
          "type": "boolean"
        }
      },
      "required": [
        "login",
        "server",
        "company",
        "name",
        "currency",
        "leverage",
        "position_mode",
        "trade_allowed",
        "trade_expert",
        "balance",
        "credit",
        "profit",
        "equity",
        "margin",
        "margin_free",
        "margin_so_mode",
        "margin_so_call",
        "margin_so_so"
