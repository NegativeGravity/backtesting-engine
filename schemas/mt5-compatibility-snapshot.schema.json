        "sample_id": {
          "$ref": "#/$defs/Identifier"
        },
        "side": {
          "$ref": "#/$defs/Side"
        },
        "symbol": {
          "$ref": "#/$defs/SymbolCode"
        },
        "volume_lots": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
