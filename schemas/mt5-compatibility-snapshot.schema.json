    "Mt5TerminalSnapshot": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "minimum": 0,
          "title": "Build",
          "type": "integer"
        },
        "commondata_path": {
          "title": "Commondata Path",
          "type": "string"
        },
        "company": {
          "title": "Company",
          "type": "string"
        },
        "connected": {
          "title": "Connected",
          "type": "boolean"
        },
        "data_path": {
          "title": "Data Path",
          "type": "string"
        },
        "maxbars": {
          "minimum": 0,
          "title": "Maxbars",
          "type": "integer"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "ping_last_us": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ping Last Us"
        },
        "trade_allowed": {
          "title": "Trade Allowed",
          "type": "boolean"
        },
        "tradeapi_disabled": {
          "title": "Tradeapi Disabled",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "company",
        "build",
        "connected",
        "trade_allowed",
        "tradeapi_disabled",
        "path",
        "data_path",
        "commondata_path",
        "maxbars"
      ],
      "title": "Mt5TerminalSnapshot",
      "type": "object"
    },
    "PositionMode": {
      "enum": [
        "netting",
        "hedging"
      ],
      "title": "PositionMode",
      "type": "string"
    },
    "SchemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "SemanticVersion": {
      "maxLength": 32,
      "minLength": 5,
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "Side": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "Side",
      "type": "string"
    },
    "SymbolCode": {
      "maxLength": 32,
      "minLength": 1,
      "pattern": "^[A-Z0-9._-]+$",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "account": {
      "$ref": "#/$defs/Mt5AccountSnapshot"
    },
    "calculation_samples": {
      "items": {
        "$ref": "#/$defs/Mt5CalculationSample"
      },
      "title": "Calculation Samples",
      "type": "array"
    },
    "captured_at": {
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion",
      "default": "1.0.0"
    },
    "snapshot_id": {
      "$ref": "#/$defs/Identifier"
    },
    "symbols": {
      "items": {
        "$ref": "#/$defs/Mt5SymbolSnapshot"
      },
      "minItems": 1,
      "title": "Symbols",
      "type": "array"
    },
    "terminal": {
      "$ref": "#/$defs/Mt5TerminalSnapshot"
    },
    "version": {
      "$ref": "#/$defs/SemanticVersion"
    }
  },
  "required": [
    "snapshot_id",
    "version",
    "terminal",
    "account",
    "symbols"
  ],
  "title": "Mt5CompatibilitySnapshot",
  "type": "object"
}
