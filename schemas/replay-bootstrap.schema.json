        "net_pnl": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Net Pnl"
        },
        "open_position_count": {
          "minimum": 0,
          "title": "Open Position Count",
          "type": "integer"
        },
        "order_count": {
          "minimum": 0,
          "title": "Order Count",
          "type": "integer"
        },
        "processed_bars": {
          "minimum": 0,
          "title": "Processed Bars",
          "type": "integer"
        },
        "rejected_order_count": {
          "minimum": 0,
          "title": "Rejected Order Count",
          "type": "integer"
        },
        "report_id": {
          "$ref": "#/$defs/Identifier"
        },
        "run_id": {
          "$ref": "#/$defs/Identifier"
        },
        "schema_version": {
          "$ref": "#/$defs/SchemaVersion",
          "default": "1.0.0"
        },
        "slippage_cost": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Slippage Cost"
        },
        "spread_cost": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Spread Cost"
        },
        "swap": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Swap"
        },
        "trade_count": {
          "minimum": 0,
