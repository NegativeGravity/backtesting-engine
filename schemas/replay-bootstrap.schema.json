      "type": "object"
    },
    "Identifier": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$",
      "type": "string"
    },
    "JsonValue": {},
    "Order": {
      "additionalProperties": false,
      "properties": {
        "accepted_time_ns": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
