            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accepted Time Ns"
        },
        "activated_time_ns": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated Time Ns"
