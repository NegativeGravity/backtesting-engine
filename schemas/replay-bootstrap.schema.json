        "revision": {
          "default": 0,
          "minimum": 0,
          "title": "Revision",
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/OrderStatus",
          "default": "created"
        },
        "terminal_time_ns": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Terminal Time Ns"
        }
      },
      "required": [
        "order_id",
        "request"
      ],
      "title": "Order",
      "type": "object"
    },
