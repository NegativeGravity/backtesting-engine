          "type": "integer"
        },
        "fill_count": {
          "minimum": 0,
          "title": "Fill Count",
          "type": "integer"
        },
        "final_account": {
          "$ref": "#/$defs/AccountSnapshot"
        },
        "gross_pnl": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
