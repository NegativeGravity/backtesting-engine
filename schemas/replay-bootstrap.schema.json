        "run_id",
        "processed_bars",
        "event_count",
        "order_count",
        "fill_count",
        "trade_count",
        "open_position_count",
        "rejected_order_count",
        "cancelled_order_count",
        "final_account",
        "gross_pnl",
        "net_pnl",
        "commission",
        "spread_cost",
        "slippage_cost",
        "swap",
        "deterministic_digest"
      ],
      "title": "BrokerSimulationReport",
      "type": "object"
    },
    "CurrencyCode": {
      "maxLength": 8,
      "minLength": 3,
      "pattern": "^[A-Z0-9]+$",
      "type": "string"
    },
    "Fill": {
      "additionalProperties": false,
      "properties": {
        "commission": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
