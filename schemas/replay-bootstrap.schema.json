              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Volume Lots"
        }
      },
      "required": [
        "client_order_id",
        "run_id",
        "strategy_instance_id",
        "symbol",
        "side",
        "order_type",
        "volume_lots",
        "created_time_ns"
