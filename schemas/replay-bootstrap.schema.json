            }
          ],
          "default": "0",
          "title": "Commission"
        },
        "fill_id": {
          "$ref": "#/$defs/Identifier"
        },
        "order_id": {
          "$ref": "#/$defs/Identifier"
        },
        "price_ticks": {
          "title": "Price Ticks",
          "type": "integer"
        },
        "run_id": {
          "$ref": "#/$defs/Identifier"
        },
        "side": {
          "$ref": "#/$defs/Side"
        },
        "slippage_cost": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Slippage Cost"
        },
        "spread_cost": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Spread Cost"
        },
        "symbol": {
          "$ref": "#/$defs/SymbolCode"
        },
        "time_ns": {
          "minimum": 0,
          "title": "Time Ns",
          "type": "integer"
        },
        "volume_lots": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Volume Lots"
        }
      },
      "required": [
        "fill_id",
        "order_id",
        "run_id",
        "symbol",
        "side",
        "time_ns",
        "price_ticks",
        "volume_lots"
      ],
