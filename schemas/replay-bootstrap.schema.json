{
  "$defs": {
    "AccountSnapshot": {
      "additionalProperties": false,
      "properties": {
        "balance": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Balance"
        },
        "currency": {
          "$ref": "#/$defs/CurrencyCode"
        },
        "drawdown_amount": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drawdown Amount"
        },
        "drawdown_percent": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drawdown Percent"
        },
        "equity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Equity"
        },
        "floating_pnl": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Floating Pnl"
        },
        "free_margin": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Free Margin"
        },
        "margin": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Margin"
        },
        "margin_level_percent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Margin Level Percent"
        },
        "peak_equity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Peak Equity"
        },
        "run_id": {
          "$ref": "#/$defs/Identifier"
        },
        "sequence": {
          "minimum": 0,
          "title": "Sequence",
          "type": "integer"
        },
        "timestamp_ns": {
          "minimum": 0,
          "title": "Timestamp Ns",
          "type": "integer"
        }
      },
      "required": [
        "run_id",
        "timestamp_ns",
        "sequence",
        "currency",
        "balance",
        "equity",
        "margin",
        "free_margin",
        "floating_pnl",
        "peak_equity",
        "drawdown_amount",
        "drawdown_percent"
      ],
      "title": "AccountSnapshot",
      "type": "object"
    },
    "BrokerSimulationReport": {
      "additionalProperties": false,
      "properties": {
        "cancelled_order_count": {
          "minimum": 0,
