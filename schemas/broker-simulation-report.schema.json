{
  "$defs": {
    "AccountSnapshot": {
      "additionalProperties": false,
      "properties": {
        "balance": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Balance"
        },
        "currency": {
          "$ref": "#/$defs/CurrencyCode"
        },
        "drawdown_amount": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drawdown Amount"
        },
        "drawdown_percent": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drawdown Percent"
        },
        "equity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Equity"
        },
        "floating_pnl": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Floating Pnl"
        },
        "free_margin": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Free Margin"
        },
        "margin": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Margin"
        },
        "margin_level_percent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Margin Level Percent"
        },
        "peak_equity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Peak Equity"
        },
        "run_id": {
          "$ref": "#/$defs/Identifier"
        },
        "sequence": {
          "minimum": 0,
          "title": "Sequence",
          "type": "integer"
        },
        "timestamp_ns": {
          "minimum": 0,
          "title": "Timestamp Ns",
          "type": "integer"
        }
      },
      "required": [
        "run_id",
        "timestamp_ns",
        "sequence",
        "currency",
        "balance",
        "equity",
        "margin",
        "free_margin",
        "floating_pnl",
        "peak_equity",
        "drawdown_amount",
        "drawdown_percent"
      ],
      "title": "AccountSnapshot",
      "type": "object"
    },
    "CurrencyCode": {
      "maxLength": 8,
      "minLength": 3,
      "pattern": "^[A-Z0-9]+$",
      "type": "string"
    },
    "Identifier": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$",
      "type": "string"
    },
    "SchemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "Sha256Hex": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "cancelled_order_count": {
      "minimum": 0,
      "title": "Cancelled Order Count",
      "type": "integer"
    },
    "commission": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Commission"
    },
    "deterministic_digest": {
      "$ref": "#/$defs/Sha256Hex"
    },
    "event_count": {
      "minimum": 0,
      "title": "Event Count",
      "type": "integer"
    },
    "fill_count": {
      "minimum": 0,
      "title": "Fill Count",
      "type": "integer"
    },
    "final_account": {
      "$ref": "#/$defs/AccountSnapshot"
    },
    "gross_pnl": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Gross Pnl"
    },
    "net_pnl": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Net Pnl"
    },
    "open_position_count": {
      "minimum": 0,
      "title": "Open Position Count",
      "type": "integer"
    },
    "order_count": {
      "minimum": 0,
      "title": "Order Count",
      "type": "integer"
    },
    "processed_bars": {
      "minimum": 0,
      "title": "Processed Bars",
      "type": "integer"
    },
    "rejected_order_count": {
      "minimum": 0,
      "title": "Rejected Order Count",
      "type": "integer"
    },
    "report_id": {
      "$ref": "#/$defs/Identifier"
    },
    "run_id": {
      "$ref": "#/$defs/Identifier"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion",
      "default": "1.0.0"
    },
    "slippage_cost": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Slippage Cost"
    },
    "spread_cost": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Spread Cost"
    },
    "swap": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Swap"
    },
    "trade_count": {
      "minimum": 0,
      "title": "Trade Count",
      "type": "integer"
    }
  },
  "required": [
    "report_id",
    "run_id",
    "processed_bars",
    "event_count",
    "order_count",
    "fill_count",
    "trade_count",
    "open_position_count",
    "rejected_order_count",
    "cancelled_order_count",
    "final_account",
    "gross_pnl",
    "net_pnl",
    "commission",
    "spread_cost",
    "slippage_cost",
    "swap",
    "deterministic_digest"
  ],
  "title": "BrokerSimulationReport",
  "type": "object"
}
