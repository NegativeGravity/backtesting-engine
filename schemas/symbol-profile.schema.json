{
  "$defs": {
    "CalculationMode": {
      "enum": [
        "forex",
        "cfd",
        "cfd_index",
        "futures"
      ],
      "title": "CalculationMode",
      "type": "string"
    },
    "CurrencyCode": {
      "maxLength": 8,
      "minLength": 3,
      "pattern": "^[A-Z0-9]+$",
      "type": "string"
    },
    "Identifier": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$",
      "type": "string"
    },
    "SchemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "SemanticVersion": {
      "maxLength": 32,
      "minLength": 5,
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "SymbolCode": {
      "maxLength": 32,
      "minLength": 1,
      "pattern": "^[A-Z0-9._-]+$",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "calculation_mode": {
      "$ref": "#/$defs/CalculationMode"
    },
    "currency_base": {
      "$ref": "#/$defs/CurrencyCode"
    },
    "currency_margin": {
      "$ref": "#/$defs/CurrencyCode"
    },
    "currency_profit": {
      "$ref": "#/$defs/CurrencyCode"
    },
    "digits": {
      "maximum": 12,
      "minimum": 0,
      "title": "Digits",
      "type": "integer"
    },
    "freeze_level_points": {
      "default": 0,
      "minimum": 0,
      "title": "Freeze Level Points",
      "type": "integer"
    },
    "margin_initial": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Margin Initial"
    },
    "margin_maintenance": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Margin Maintenance"
    },
    "metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Metadata",
      "type": "object"
    },
    "point": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Point"
    },
    "profile_id": {
      "$ref": "#/$defs/Identifier"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion",
      "default": "1.0.0"
    },
    "stops_level_points": {
      "default": 0,
      "minimum": 0,
      "title": "Stops Level Points",
      "type": "integer"
    },
    "symbol": {
      "$ref": "#/$defs/SymbolCode"
    },
    "trade_contract_size": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Trade Contract Size"
    },
    "trade_tick_size": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Trade Tick Size"
    },
    "trade_tick_value": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Trade Tick Value"
    },
    "trade_tick_value_loss": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trade Tick Value Loss"
    },
    "trade_tick_value_profit": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trade Tick Value Profit"
    },
    "version": {
      "$ref": "#/$defs/SemanticVersion"
    },
    "volume_max": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Volume Max"
    },
    "volume_min": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Volume Min"
    },
    "volume_step": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Volume Step"
    }
  },
  "required": [
    "profile_id",
    "version",
    "symbol",
    "calculation_mode",
    "currency_base",
    "currency_profit",
    "currency_margin",
    "digits",
    "point",
    "trade_tick_size",
    "trade_tick_value",
    "trade_contract_size",
    "volume_min",
    "volume_max",
    "volume_step"
  ],
  "title": "SymbolProfile",
  "type": "object"
}
